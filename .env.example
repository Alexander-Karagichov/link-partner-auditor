# ============================================================
# LINK PARTNER AUDITOR - Environment Variables
# Copy this file to .env and fill in the providers you actually use.
# ============================================================

# ── SEO data provider: "semrush" (default) or "dataforseo" ──────────────────
SEO_PROVIDER=semrush

# SEMrush (used when SEO_PROVIDER=semrush) — semrush.com -> Account -> API
SEMRUSH_API_KEY=your_semrush_api_key_here
SEMRUSH_TOP_COUNTRIES=1                  # audit the domain's top-N traffic countries (1 = #1 market, cheapest)

# DataForSEO (used when SEO_PROVIDER=dataforseo) — app.dataforseo.com/api-access
DATAFORSEO_LOGIN=your_dataforseo_login_here
DATAFORSEO_PASSWORD=your_dataforseo_password_here
DATAFORSEO_LOCATION_CODE=2840          # 2840 = United States
DATAFORSEO_LANGUAGE=English

# ── Bright Data (web scraping + Google SERP) — brightdata.com/cp/setting/users ─
BRIGHTDATA_API_KEY=your_bright_data_api_key_here
BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker1
BRIGHTDATA_SERP_ZONE=serp_api_marketing_make_com

# ── AI provider: "openai" (default) or "anthropic" ──────────────────────────
LLM_PROVIDER=openai

# OpenAI (used when LLM_PROVIDER=openai) — platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-5.2

# Anthropic / Claude (used when LLM_PROVIDER=anthropic) — console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-opus-4-8

# ── Reciprocal-link (PBN / link-scheme) check ───────────────────────────────
RECIPROCAL_MAX_CHECKS=10                 # max outbound "strange" domains fetched for reciprocity
ENABLE_RECIPROCITY=true                  # set to false to skip reciprocity fetches entirely

# ── App settings ────────────────────────────────────────────────────────────
MAX_CONCURRENT_AUDITS=3
REQUEST_TIMEOUT=60
MAX_KEYWORDS_CHECK=50

# ── Throughput / reliability tuning (optional) ──────────────────────────────
INNER_CONCURRENCY=5                     # sub-queries per domain run at once (lower = gentler on APIs)
BRIGHTDATA_TIMEOUT=60                    # seconds
BRIGHTDATA_MAX_RETRIES=2
MAX_DEEP_PAGES_PER_DOMAIN=25             # cap deep-checked pages per domain
