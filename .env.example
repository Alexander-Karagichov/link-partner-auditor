# ============================================================
# WEBSITE AUDIT AUTOMATION - Environment Variables
# ============================================================
# Copy this file to .env and fill in your API keys

# --- SEMrush ---
SEMRUSH_API_KEY=your_semrush_api_key_here

# --- Bright Data ---
# Your Bright Data API Key (Bearer token) — found at brightdata.com/cp/setting/users
BRIGHTDATA_API_KEY=your_bright_data_api_key_here
# Zone names (defaults shown; change only if yours differ)
BRIGHTDATA_WEB_UNLOCKER_ZONE=web_unlocker1
BRIGHTDATA_SERP_ZONE=serp_api_marketing_make_com

# --- OpenAI ---
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# --- App Settings ---
# Max concurrent domains to audit at once
MAX_CONCURRENT_AUDITS=3
# Request timeout in seconds
REQUEST_TIMEOUT=30
# Max keywords to check for organic rankings (per category)
MAX_KEYWORDS_CHECK=50
